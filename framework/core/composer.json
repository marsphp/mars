{
  "name": "mars/core",
  "description": "The Mars Core package.",
  "license": "MIT",
  "homepage": "",
  "support": {
    "issues": "https://github.com/marsphp/mars/issues",
    "source": "https://github.com/marsphp/mars"
  },
  "keywords": ["framework", "mars"],
  "authors": [
    {
      "name": "Hassane Dao",
      "email": "dao.hassane@gmail.com"
    },
    {
      "name": "Houssene Dao",
      "email": "dao.houssene@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Mars\\Core\\": "src/"
    }
  },
  "require": {
    "php": "^7.3|^8.0",
    "ext-json": "*"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "../collection"
    },
    {
      "type": "path",
      "url": "../container"
    },
    {
      "type": "path",
      "url": "../helpers"
    },
    {
      "type": "path",
      "url": "../logging"
    },
    {
      "type": "path",
      "url": "../migration"
    },
    {
      "type": "path",
      "url": "../routing"
    },
    {
      "type": "path",
      "url": "./session"
    }
  ]
}
