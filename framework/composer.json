{
  "name": "mars/framework",
  "description": "Mars framework",
  "keywords": ["framework", "mars"],
  "license": "MIT",
  "homepage": "https://mars.dev",
  "support": {
    "issues": "https://github.com/marsphp/framework/issues",
    "source": "https://github.com/marsphp/framework"
  },
  "authors": [
    {
      "name": "Hassane Dao",
      "email": "dao.hassane@gmail.com"
    },
    {
      "name": "Houssene Dao",
      "email": "dao.houssene@gmail.com"
    }
  ],
  "require": {
    "php": "^7.4|^8.0",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-openssl": "*",
    "league/route": "^4.5",
    "league/event": "^3.0",
    "vlucas/phpdotenv": "^5.2",
    "voku/portable-ascii": "^1.4.8"
  },
  "require-dev": {},
  "provide": {
    "psr/container-implementation": "1.0"
  },
  "conflict": {
    "tightenco/collect": "<5.5.33"
  },
  "autoload": {
    "files": [
      "src/Mars/Support/helpers.php"
    ],
    "psr-4": {
      "Mars\\": "src/Mars/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Mars\\Tests\\": "tests/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-master": "1.x-dev"
    }
  },
  "suggest": {},
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
